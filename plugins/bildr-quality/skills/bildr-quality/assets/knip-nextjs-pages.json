{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "pages/**/*.{ts,tsx}",
    "next.config.{js,ts,mjs}",
    "drizzle.config.{ts,js}"
  ],
  "project": [
    "pages/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "utils/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "**/*.test.{ts,tsx}",
    "**/*.spec.{ts,tsx}",
    "**/__tests__/**",
    "**/test-fixtures/**",
    "drizzle/**"
  ],
  "ignoreDependencies": [],
  "ignoreExportsUsedInFile": true
}
